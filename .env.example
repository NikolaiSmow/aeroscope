# OpenSky Network - register a free account at https://opensky-network.org/
# Without these, the API works anonymously (10s resolution, 400 credits/day per IP).
# Create an API client from your OpenSky account page and use OAuth2 client credentials.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AeroDataBox - free trial via RapidAPI (300-600 calls/month).
# https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Without this, click-for-details shows only OpenSky's live fields.
RAPIDAPI_KEY=

# Upstash Redis - durable L2 cache for aircraft metadata across restarts/instances.
# Free tier: 10k commands/day, 256 MB storage. https://upstash.com/
# Without these, metadata still caches in-memory (lost on process restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
