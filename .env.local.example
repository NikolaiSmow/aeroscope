# OpenSky Network — register a free account at https://opensky-network.org/
# Without these, the API works anonymously (10s resolution, 400 credits/day per IP).
OPENSKY_USER=
OPENSKY_PASS=

# AeroDataBox — free trial via RapidAPI (300–600 calls/month).
# https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Without this, click-for-details shows only OpenSky's live fields.
RAPIDAPI_KEY=

# Toggle UI hint when the metadata key is configured.
NEXT_PUBLIC_HAS_METADATA_KEY=0
